# ═══════════════════════════════════════
#  Kii Akira — Environment Variables
#  Copy this to .env and fill in values
# ═══════════════════════════════════════

# ── Discord OAuth App ──────────────────
# Get from: https://discord.com/developers/applications
# → Your App → OAuth2 → General
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Must EXACTLY match what you add in Discord Dev Portal → OAuth2 → Redirects
# Local dev:
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback
# Production (replace with your real domain):
# DISCORD_REDIRECT_URI=https://yourdomain.com/auth/callback

# ── App Settings ──────────────────────
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string-like-abc123xyz789

# Where your frontend HTML is served from (for CORS)
FRONTEND_URL=http://localhost:3000

# ── Email (optional — for verification codes) ─────────────
# Using Gmail:
#   1. Go to myaccount.google.com → Security → App Passwords
#   2. Create a password for "Mail" and paste it as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password_here
